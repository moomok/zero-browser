<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ZeroBrowser.App.ViewModels"
        x:Class="ZeroBrowser.App.Views.ProfileEditorWindow"
        x:DataType="vm:ProfileEditorViewModel"
        Width="680" Height="740"
        WindowStartupLocation="CenterOwner"
        Icon="/Assets/icon.png"
        Title="{Binding Title}">
    <Grid Margin="16" RowDefinitions="Auto,*,Auto">
        <TextBlock Grid.Row="0" Text="{Binding Title}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="14">

                <StackPanel>
                    <TextBlock Text="Name" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox PlaceholderText="My profile" Text="{Binding Name, Mode=TwoWay}" />
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Operating system (fingerprint)" FontSize="12" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding OsOptions}"
                              SelectedItem="{Binding SelectedOs, Mode=TwoWay}"
                              HorizontalAlignment="Stretch">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:OsOption">
                                <TextBlock Text="{Binding Display}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Proxy" FontSize="12" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding ProxyOptions}"
                              SelectedItem="{Binding SelectedProxy, Mode=TwoWay}"
                              HorizontalAlignment="Stretch">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:ProxyOption">
                                <TextBlock Text="{Binding Display}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Fingerprint seed (deterministic)" FontSize="12" Margin="0,0,0,4"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBox Grid.Column="0" Text="{Binding FingerprintSeed, Mode=TwoWay}"
                                 FontFamily="Consolas,Menlo,monospace" FontSize="12"/>
                        <Button Grid.Column="1" Margin="8,0,0,0"
                                Content="Regenerate"
                                Command="{Binding RegenerateCommand}"/>
                    </Grid>
                    <TextBlock Text="Same seed = same fingerprint, every time."
                               FontSize="11" Opacity="0.6" Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel>
                    <TextBlock Text="Engine (Chromium binary)" FontSize="12" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding EngineOptions}"
                              SelectedItem="{Binding SelectedEngine, Mode=TwoWay}"
                              HorizontalAlignment="Stretch">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:EngineOption">
                                <TextBlock Text="{Binding Display}" TextTrimming="CharacterEllipsis"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBlock Text="Pick an installed Chrome / Brave / Edge for full Web Store access. The default 'Chromium for Testing' is deterministic but cannot install Web Store extensions interactively."
                               FontSize="11" Opacity="0.6" TextWrapping="Wrap" Margin="0,4,0,0"/>
                </StackPanel>

                <Border BorderBrush="#22000000" BorderThickness="1" CornerRadius="6" Padding="12">
                    <StackPanel Spacing="6">
                        <Grid ColumnDefinitions="*,Auto,Auto">
                            <TextBlock Grid.Column="0" Text="Extensions" FontWeight="SemiBold" FontSize="13"
                                       VerticalAlignment="Center"/>
                            <Button   Grid.Column="1" Content="Add folder" Margin="0,0,4,0"
                                      Command="{Binding AddExtensionFolderCommand}"/>
                            <Button   Grid.Column="2" Content="Import .crx"
                                      Command="{Binding AddExtensionCrxCommand}"/>
                        </Grid>

                        <ItemsControl ItemsSource="{Binding Extensions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ExtensionItemViewModel">
                                    <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,4,0,0">
                                        <CheckBox Grid.Column="0" Margin="0,0,8,0"
                                                  IsChecked="{Binding Enabled, Mode=TwoWay}"
                                                  ToolTip.Tip="Toggle this extension on/off for the next launch."/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding DisplayName}" FontSize="13"/>
                                            <TextBlock Text="{Binding Path}" FontSize="11" Opacity="0.55"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <Button Grid.Column="2" Content="Remove" FontSize="11"
                                                Command="{Binding $parent[ItemsControl].((vm:ProfileEditorViewModel)DataContext).RemoveExtensionCommand}"
                                                CommandParameter="{Binding}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <TextBlock Text="{Binding ExtensionStatusMessage}"
                                   FontSize="11" Opacity="0.7" Margin="0,4,0,0"
                                   IsVisible="{Binding ExtensionStatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                        <TextBlock Text="Tip: Folder must contain manifest.json. Drop a CRX to auto-extract."
                                   FontSize="11" Opacity="0.55" Margin="0,4,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <StackPanel>
                    <TextBlock Text="Notes" FontSize="12" Margin="0,0,0,4"/>
                    <TextBox AcceptsReturn="True" MinHeight="60" MaxHeight="120"
                             TextWrapping="Wrap"
                             Text="{Binding Notes, Mode=TwoWay}" />
                </StackPanel>

                <Border BorderBrush="#22000000" BorderThickness="1" CornerRadius="6" Padding="12">
                    <StackPanel Spacing="6">
                        <TextBlock Text="Live preview" FontWeight="SemiBold" FontSize="13"/>
                        <Grid ColumnDefinitions="100,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="UA"      Opacity="0.6" FontSize="11"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding PreviewUserAgent}" FontSize="11" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Timezone" Opacity="0.6" FontSize="11"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding PreviewTimezone}" FontSize="11"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Screen"   Opacity="0.6" FontSize="11"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding PreviewScreen}"   FontSize="11"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="GPU"      Opacity="0.6" FontSize="11"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding PreviewGpu}"      FontSize="11"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Language" Opacity="0.6" FontSize="11"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding PreviewLanguage}" FontSize="11"/>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8"
                    HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancel" Command="{Binding CancelCommand}" />
            <Button Content="Save"   Command="{Binding SaveCommand}" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
