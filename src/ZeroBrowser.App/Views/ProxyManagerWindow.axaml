<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ZeroBrowser.App.ViewModels"
        x:Class="ZeroBrowser.App.Views.ProxyManagerWindow"
        x:DataType="vm:ProxyManagerViewModel"
        Width="900" Height="640"
        WindowStartupLocation="CenterOwner"
        Icon="/Assets/icon.png"
        Title="Proxy manager">
    <Grid Margin="16" RowDefinitions="Auto,*,Auto,Auto,Auto">
        <TextBlock Grid.Row="0" Text="Proxies" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>

        <Border Grid.Row="1" BorderBrush="#22000000" BorderThickness="1" CornerRadius="6">
            <DataGrid ItemsSource="{Binding Proxies}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Type"   Binding="{Binding Type}"   Width="80"/>
                    <DataGridTextColumn Header="Host"   Binding="{Binding Host}"   Width="200"/>
                    <DataGridTextColumn Header="Port"   Binding="{Binding Port}"   Width="80"/>
                    <DataGridTextColumn Header="Auth"   Binding="{Binding Auth}"   Width="160"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="120"/>
                    <DataGridTemplateColumn Header="Actions" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate x:DataType="vm:ProxyItemViewModel">
                                <Button Content="Delete" Margin="6"
                                        Command="{Binding $parent[Window].((vm:ProxyManagerViewModel)DataContext).DeleteCommand}"
                                        CommandParameter="{Binding}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <TextBlock Grid.Row="2"
                   Margin="0,16,0,4"
                   Text="Bulk import (one per line) — supports: host:port, host:port:user:pass, user:pass@host:port, scheme://[user:pass@]host:port"
                   FontSize="12" Opacity="0.7" TextWrapping="Wrap"/>

        <TextBox Grid.Row="3"
                 AcceptsReturn="True"
                 TextWrapping="NoWrap"
                 MinHeight="120"
                 MaxHeight="200"
                 FontFamily="Consolas,Menlo,monospace"
                 FontSize="12"
                 PlaceholderText="1.2.3.4:8080&#10;https://user:pass@proxy.example.com:443&#10;socks5://10.0.0.1:1080"
                 Text="{Binding BulkInput, Mode=TwoWay}"/>

        <Grid Grid.Row="4" Margin="0,12,0,0" ColumnDefinitions="*,Auto,Auto,Auto">
            <TextBlock Grid.Column="0"
                       Text="{Binding StatusMessage}"
                       VerticalAlignment="Center" FontSize="12" Opacity="0.7"/>
            <Button Grid.Column="1" Content="Reload"  Command="{Binding ReloadCommand}" Margin="0,0,8,0"/>
            <Button Grid.Column="2" Content="Import"  Command="{Binding ImportCommand}" Margin="0,0,8,0"/>
            <Button Grid.Column="3" Content="Close"   Click="OnCloseClick"/>
        </Grid>
    </Grid>
</Window>
