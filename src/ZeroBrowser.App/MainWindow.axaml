<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:ZeroBrowser.App.ViewModels"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="650"
        x:Class="ZeroBrowser.App.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="980" Height="640"
        MinWidth="780" MinHeight="500"
        Icon="/Assets/icon.png"
        Title="Zero Browser">
  <Grid RowDefinitions="Auto,*,Auto" Margin="12">
    <!-- Toolbar -->
    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
      <Button Content="New profile"  Command="{Binding NewProfileCommand}" />
      <Button Content="Proxies"      Command="{Binding OpenProxyManagerCommand}" />
      <Button Content="Reload"       Command="{Binding ReloadCommand}" />
      <TextBlock Text="Zero Browser — multi-profile fingerprint manager"
                 VerticalAlignment="Center" Margin="20,0,0,0"
                 Opacity="0.7" FontSize="13" />
    </StackPanel>

    <!-- Profile list -->
    <Border Grid.Row="1" BorderBrush="#33000000" BorderThickness="1" CornerRadius="6">
      <DataGrid ItemsSource="{Binding Profiles}"
                AutoGenerateColumns="False"
                CanUserResizeColumns="True"
                IsReadOnly="True"
                GridLinesVisibility="Horizontal"
                HeadersVisibility="Column"
                SelectionMode="Single">
        <DataGrid.Columns>
          <DataGridTextColumn Header="Name"      Binding="{Binding Name}"       Width="160"/>
          <DataGridTextColumn Header="OS"        Binding="{Binding Os}"         Width="80"/>
          <DataGridTextColumn Header="Browser"   Binding="{Binding Browser}"    Width="80"/>
          <DataGridTextColumn Header="Screen"    Binding="{Binding Resolution}" Width="100"/>
          <DataGridTextColumn Header="Timezone"  Binding="{Binding Timezone}"   Width="130"/>
          <DataGridTextColumn Header="Status"    Binding="{Binding Status}"     Width="70"/>
          <DataGridTemplateColumn Header="Actions" Width="*" MinWidth="320">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate x:DataType="vm:ProfileItemViewModel">
                <StackPanel Orientation="Horizontal" Spacing="4" Margin="4,2">
                  <Button Content="Preview" Padding="8,4" FontSize="12"
                          ToolTip.Tip="Show full fingerprint summary"
                          Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).PreviewFingerprintCommand}"
                          CommandParameter="{Binding}" />
                  <Button Content="Edit" Padding="8,4" FontSize="12"
                          ToolTip.Tip="Edit name, OS, proxy, seed"
                          Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).EditProfileCommand}"
                          CommandParameter="{Binding}" />
                  <Button Content="Cookies" Padding="8,4" FontSize="12"
                          ToolTip.Tip="Import cookies (JSON / Netscape)"
                          Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ImportCookiesCommand}"
                          CommandParameter="{Binding}" />
                  <Button Content="Launch" Padding="10,4" FontSize="12" FontWeight="SemiBold"
                          ToolTip.Tip="Open Chromium with this fingerprint"
                          Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).LaunchCommand}"
                          CommandParameter="{Binding}" />
                  <Button Content="Delete" Padding="8,4" FontSize="12"
                          ToolTip.Tip="Remove this profile"
                          Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).DeleteProfileCommand}"
                          CommandParameter="{Binding}" />
                </StackPanel>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
        </DataGrid.Columns>
      </DataGrid>
    </Border>

    <!-- Status bar -->
    <Border Grid.Row="2" Background="#11000000" CornerRadius="4" Margin="0,12,0,0" Padding="8,4">
      <TextBlock Text="{Binding StatusMessage}" FontSize="12" Opacity="0.8" />
    </Border>
  </Grid>
</Window>
