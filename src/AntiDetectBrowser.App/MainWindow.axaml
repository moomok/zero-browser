<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:AntiDetectBrowser.App.ViewModels"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="650"
        x:Class="AntiDetectBrowser.App.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1100" Height="650"
        Title="AntiDetect Browser">
  <Grid RowDefinitions="Auto,*,Auto" Margin="12">
    <!-- Toolbar -->
    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,12">
      <Button Content="New profile"  Command="{Binding NewProfileCommand}" />
      <Button Content="Reload"       Command="{Binding ReloadCommand}" />
      <TextBlock Text="AntiDetect Browser — multi-profile fingerprint manager"
                 VerticalAlignment="Center" Margin="20,0,0,0"
                 Opacity="0.7" FontSize="13" />
    </StackPanel>

    <!-- Profile list -->
    <Border Grid.Row="1" BorderBrush="#33000000" BorderThickness="1" CornerRadius="6">
      <DataGrid ItemsSource="{Binding Profiles}"
                AutoGenerateColumns="False"
                CanUserResizeColumns="True"
                IsReadOnly="True"
                GridLinesVisibility="Horizontal"
                HeadersVisibility="Column"
                SelectionMode="Single">
        <DataGrid.Columns>
          <DataGridTextColumn Header="Name"      Binding="{Binding Name}"      Width="200"/>
          <DataGridTextColumn Header="OS"        Binding="{Binding Os}"        Width="120"/>
          <DataGridTextColumn Header="Browser"   Binding="{Binding Browser}"   Width="100"/>
          <DataGridTextColumn Header="Screen"    Binding="{Binding Resolution}" Width="120"/>
          <DataGridTextColumn Header="Timezone"  Binding="{Binding Timezone}"  Width="180"/>
          <DataGridTextColumn Header="Lang"      Binding="{Binding Language}"  Width="80"/>
          <DataGridTextColumn Header="Last used" Binding="{Binding LastUsed}"  Width="140"/>
          <DataGridTextColumn Header="Status"    Binding="{Binding Status}"    Width="100"/>
          <DataGridTemplateColumn Header="Actions" Width="*">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate x:DataType="vm:ProfileItemViewModel">
                <StackPanel Orientation="Horizontal" Spacing="6" Margin="6">
                  <Button Content="Launch"
                          Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).LaunchCommand}"
                          CommandParameter="{Binding}" />
                  <Button Content="Delete"
                          Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).DeleteProfileCommand}"
                          CommandParameter="{Binding}" />
                </StackPanel>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
        </DataGrid.Columns>
      </DataGrid>
    </Border>

    <!-- Status bar -->
    <Border Grid.Row="2" Background="#11000000" CornerRadius="4" Margin="0,12,0,0" Padding="8,4">
      <TextBlock Text="{Binding StatusMessage}" FontSize="12" Opacity="0.8" />
    </Border>
  </Grid>
</Window>
